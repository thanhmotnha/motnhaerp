// ============ PHÂN HỆ TIẾN ĐỘ V2 ============

model ScheduleTask {
  id              String   @id @default(cuid())
  name            String
  order           Int      @default(0)
  level           Int      @default(0)
  wbs             String   @default("")
  startDate       DateTime
  endDate         DateTime
  duration        Int      @default(1)
  progress        Int      @default(0)
  weight          Float    @default(1)
  status          String   @default("Chưa bắt đầu")
  isLocked        Boolean  @default(false)
  assignee        String   @default("")
  notes           String   @default("")
  color           String   @default("")
  baselineStart   DateTime?
  baselineEnd     DateTime?
  parentId        String?
  parent          ScheduleTask?  @relation("TaskTree", fields: [parentId], references: [id])
  children        ScheduleTask[] @relation("TaskTree")
  predecessorId   String?
  predecessor     ScheduleTask?  @relation("TaskDep", fields: [predecessorId], references: [id])
  successors      ScheduleTask[] @relation("TaskDep")
  dependencies    TaskDependency[] @relation("TaskDependencies")
  dependents      TaskDependency[] @relation("TaskDependents")
  contractors     SubContractorTask[]
  workOrders      WorkOrder[]    @relation("TaskWorkOrders")
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id])
  progressReports ProgressReport[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([projectId])
  @@index([parentId])
}

model TaskDependency {
  id           String       @id @default(cuid())
  taskId       String
  task         ScheduleTask @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnId  String
  dependsOn    ScheduleTask @relation("TaskDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)
  type         String       @default("FS") // FS, SS, FF, SF
  lag          Int          @default(0)     // days
  createdAt    DateTime     @default(now())
  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
}

model SubContractorTask {
  id                String     @id @default(cuid())
  contractorId      String
  contractor        Contractor @relation(fields: [contractorId], references: [id])
  taskId            String
  task              ScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignedAt        DateTime   @default(now())
  completionPercent Int        @default(0)
  notes             String     @default("")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  @@unique([contractorId, taskId])
  @@index([contractorId])
  @@index([taskId])
}

model ProgressReport {
  id            String   @id @default(cuid())
  progressFrom  Int      @default(0)
  progressTo    Int
  description   String   @default("") @db.Text
  images        String   @default("[]") @db.Text
  status        String   @default("Đã duyệt")
  rejectionNote String   @default("")
  reportDate    DateTime @default(now())
  createdBy     String   @default("")
  taskId        String
  task          ScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id])
  createdAt     DateTime @default(now())
  @@index([taskId])
  @@index([projectId])
}

model ScheduleTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("Nội thất")
  description String   @default("")
  items       ScheduleTemplateItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScheduleTemplateItem {
  id            String   @id @default(cuid())
  name          String
  order         Int      @default(0)
  level         Int      @default(0)
  wbs           String   @default("")
  duration      Int      @default(1)
  weight        Float    @default(1)
  color         String   @default("")
  parentId      String?
  parent        ScheduleTemplateItem? @relation("TplItemTree", fields: [parentId], references: [id])
  children      ScheduleTemplateItem[] @relation("TplItemTree")
  predecessorId String?
  predecessor   ScheduleTemplateItem? @relation("TplItemDep", fields: [predecessorId], references: [id])
  successors    ScheduleTemplateItem[] @relation("TplItemDep")
  templateId    String
  template      ScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id])
  source      String       @default("paste")
  rawInput    String       @db.Text
  aiSummary   String?      @db.Text
  aiRaw       Json?
  createdBy   String       @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  commitments Commitment[]
  @@index([projectId])
}

model Commitment {
  id             String        @id @default(cuid())
  journalEntryId String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id])
  title          String
  type           String        @default("yêu cầu")
  assignee       String        @default("")
  deadline       DateTime?
  status         String        @default("pending")
  notes          String        @default("") @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  @@index([projectId])
  @@index([journalEntryId])
  @@index([status])
}

// ============ AUDIT TRAIL ============

model ActivityLog {
  id          String   @id @default(cuid())
  actor       String   @default("")
  actorId     String   @default("")
  action      String
  entityType  String
  entityId    String
  entityLabel String   @default("")
  diff        Json?
  metadata    Json?
  ipAddress   String   @default("")
  createdAt   DateTime @default(now())
  @@index([entityType, entityId])
  @@index([actor])
  @@index([createdAt])
}

// ============ PUNCH LIST ============

model PunchListItem {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  area        String   @default("")
  description String   @db.Text
  images      String   @default("[]") @db.Text
  assignee    String   @default("")
  assigneeId  String?
  priority    String   @default("Trung bình") // Cao, Trung bình, Thấp
  deadline    DateTime?
  status      String   @default("Mở")
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([projectId])
  @@index([assigneeId])
}

// ============ HR CHẤM CÔNG ============

model Attendance {
