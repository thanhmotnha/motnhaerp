generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemSetting {
  key       String   @id @db.VarChar(100)
  value     String   @default("")
  updatedAt DateTime @default(now()) @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("ky_thuat")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pushToken String   @default("")
  username  String   @default("")
  phone     String   @default("")
  zaloUserId String  @default("")

  salesCustomers Customer[]     @relation("CustomerSalesPerson")

  @@index([username])
}

model WorkshopTask {
  id          String    @id @default(cuid())
  title       String
  description String    @default("") @db.Text
  projectId   String?
  project     Project?  @relation("WorkshopTaskProject", fields: [projectId], references: [id])
  startDate   DateTime?
  deadline    DateTime?
  progress    Int       @default(0)
  status      String    @default("Chờ làm")
  category    String    @default("Lắp ghép tại xưởng")
  priority    String    @default("Trung bình")
  isLocked    Boolean   @default(false)
  notes       String    @default("") @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workers     WorkshopTaskWorker[]
  materials   WorkshopTaskMaterial[]
  @@index([projectId])
}

model WorkshopWorker {
  id          String   @id @default(cuid())
  name        String
  workerType  String   @default("Thợ chính")
  skill       String   @default("")
  phone       String   @default("")
  status      String   @default("Hoạt động")
  hourlyRate  Float    @default(0)
  notes       String   @default("") @db.Text
  zaloUserId  String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       WorkshopTaskWorker[]
  attendances WorkshopAttendance[]
}

model WorkshopTaskWorker {
  taskId   String
  workerId String
  task     WorkshopTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  worker   WorkshopWorker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  @@id([taskId, workerId])
}

model WorkshopTaskMaterial {
  id        String       @id @default(cuid())
  taskId    String
  productId String
  quantity  Float        @default(1)
  task      WorkshopTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id])
  @@index([taskId])
  @@index([productId])
}

model WorkLogEntry {
  id          String    @id @default(cuid())
  date        DateTime
  shift       String    @default("Sáng")
  category    String
  projectId   String?
  projectName String    @default("")
  mainWorkers String    @default("[]")
  subWorkers  String    @default("[]")
  note        String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project?  @relation("ProjectWorkLog", fields: [projectId], references: [id])
  @@index([date])
  @@index([projectId])
}

model WorkshopAttendance {
  id          String         @id @default(cuid())
  workerId    String
  worker      WorkshopWorker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  date        DateTime
  hoursWorked Float          @default(8)
  notes       String         @default("")
  createdAt   DateTime       @default(now())
  @@index([workerId])
  @@unique([workerId, date])
}

model Customer {
  id              String                @id @default(cuid())
  code            String                @unique
  name            String
  phone           String
  email           String                @default("")
  address         String                @default("")
  type            String                @default("Cá nhân")
  status          String                @default("Lead")
  taxCode         String                @default("")
  representative  String                @default("")
  birthday        DateTime?
  source          String                @default("")
  notes           String                @default("")
  totalRevenue    Float                 @default(0)
  gender          String                @default("Nam")
  projectAddress  String                @default("")
  projectName     String                @default("")
  salesPersonNote String                @default("")
  salesPersonId   String?
  salesPerson     User?                 @relation("CustomerSalesPerson", fields: [salesPersonId], references: [id], onDelete: SetNull)
  designer        String                @default("")
  contactPerson2  String                @default("")
  phone2          String                @default("")
  pipelineStage   String                @default("Lead")
  estimatedValue  Float                 @default(0)
  nextFollowUp    DateTime?
  score           Int                   @default(0)
  lastContactAt   DateTime?
  deletedAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  citizenId       String                @default("")
  lostReason      String                @default("")
  tags            String                @default("")
  facebookLeadId  String                @default("")
  facebookUrl     String                @default("")
  contracts       Contract[]
  interactions    CustomerInteraction[]
  furnitureOrders FurnitureOrder[]
  projects        Project[]
  documents       ProjectDocument[]
  quotations      Quotation[]
  trackingLogs    TrackingLog[]

  @@index([salesPersonId])
}

model Project {
  id                    String                 @id @default(cuid())
  code                  String                 @unique
  name                  String
  type                  String
  address               String                 @default("")
  description           String                 @default("")
  area                  Float                  @default(0)
  floors                Int                    @default(0)
  budget                Float                  @default(0)
  spent                 Float                  @default(0)
  contractValue         Float                  @default(0)
  paidAmount            Float                  @default(0)
  status                String                 @default("Khảo sát")
  phase                 String                 @default("")
  progress              Int                    @default(0)
  startDate             DateTime?
  endDate               DateTime?
  manager               String                 @default("")
  notes                 String                 @default("")
  customerId            String
  deletedAt             DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  designer              String                 @default("")
  supervisor            String                 @default("")
  budgetLockedAt        DateTime?
  budgetLockedBy        String                 @default("")
  budgetStatus          String                 @default("draft")
  budgetTotal           Float                  @default(0)
  siteReadyFlag         Boolean                @default(false)
  acceptanceReports     AcceptanceReport[]
  accountEntries        AccountEntry[]
  changeOrders          BudgetChangeOrder[]
  portalTokens          ClientPortalToken[]
  commitments           Commitment[]
  contracts             Contract[]
  contractorPays        ContractorPayment[]
  contractorPaymentLogs ContractorPaymentLog[]
  documentFolders       DocumentFolder[]
  expenseAllocations    ExpenseAllocation[]
  furnitureOrders       FurnitureOrder[]
  inventoryTx           InventoryTransaction[]
  journalEntries        JournalEntry[]
  materialPlans         MaterialPlan[]
  requisitions          MaterialRequisition[]
  photos                ProgressPhoto[]
  progressReports       ProgressReport[]
  customer              Customer               @relation(fields: [customerId], references: [id])
  budgets               ProjectBudget[]
  documents             ProjectDocument[]
  employees             ProjectEmployee[]
  expenses              ProjectExpense[]
  milestones            ProjectMilestone[]
  projectRisks          ProjectRisk[]
  punchListItems        PunchListItem[]
  purchaseOrders        PurchaseOrder[]
  purchaseOrderItems    PurchaseOrderItem[]    @relation("PurchaseOrderItemProject")
  quotations            Quotation[]
  resources             ResourceAllocation[]
  risks                 RiskEntry[]
  scheduleTasks         ScheduleTask[]
  siteLogs              SiteLog[]
  trackingLogs          TrackingLog[]
  transactions          Transaction[]
  warrantyTickets       WarrantyTicket[]
  workOrders            WorkOrder[]
  overheadAllocations   OverheadAllocation[]
  stockIssues           StockIssue[]
  supplierDebts         SupplierDebt[]
  contractorDebts       ContractorDebt[]
  workshopTasks         WorkshopTask[]       @relation("WorkshopTaskProject")
  workLogEntries        WorkLogEntry[]       @relation("ProjectWorkLog")

  @@index([customerId])
}

model ProductCategory {
  id        String            @id @default(cuid())
  name      String
  slug      String            @default("")
  order     Int               @default(0)
  parentId  String?
  createdAt DateTime          @default(now())
  products  Product[]
  parent    ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("CategoryTree")

  @@index([parentId])
}

model Product {
  id                     String                  @id @default(cuid())
  code                   String                  @unique
  name                   String
  category               String
  unit                   String
  importPrice            Float                   @default(0)
  salePrice              Float                   @default(0)
  stock                  Int                     @default(0)
  minStock               Int                     @default(0)
  supplier               String                  @default("")
  description            String                  @default("")
  dimensions             String                  @default("")
  weight                 Float                   @default(0)
  color                  String                  @default("")
  material               String                  @default("")
  origin                 String                  @default("")
  warranty               String                  @default("")
  brand                  String                  @default("")
  status                 String                  @default("Đang bán")
  supplyType             String                  @default("Vật tư lưu kho")
  leadTimeDays           Int                     @default(0)
  location               String                  @default("")
  image                  String                  @default("")
  deletedAt              DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  coreBoard              String                  @default("")
  surfaceCode            String                  @default("")
  categoryId             String?
  warehouseId            String?
  warehouse              Warehouse?              @relation(fields: [warehouseId], references: [id])
  reorderPoint           Int                     @default(0)
  furnitureOrderItems    FurnitureOrderItem[]
  inventoryTx            InventoryTransaction[]
  materialPlans          MaterialPlan[]
  materialSelectionItems MaterialSelectionItem[]
  workshopTaskMaterials  WorkshopTaskMaterial[]
  categoryRef            ProductCategory?        @relation(fields: [categoryId], references: [id])
  attributes             ProductAttribute[]
  bomUsedIn              ProductBOM[]            @relation("BOMComponent")
  bomComponents          ProductBOM[]            @relation("BOMParent")
  purchaseItems          PurchaseOrderItem[]
  quotationItems         QuotationItem[]
  warehouseTransfers     WarehouseTransfer[]
  receiptItems           GoodsReceiptItem[]
  issueItems             StockIssueItem[]
  stockTakingItems       StockTakingItem[]

  @@index([categoryId])
  @@index([warehouseId])
}

model Quotation {
  id                String              @id @default(cuid())
  code              String              @unique
  total             Float               @default(0)
  discount          Float               @default(0)
  vat               Float               @default(10)
  grandTotal        Float               @default(0)
  status            String              @default("Nháp")
  validUntil        DateTime?
  notes             String              @default("")
  type              String              @default("Thi công")
  directCost        Float               @default(0)
  managementFeeRate Float               @default(5)
  managementFee     Float               @default(0)
  designFee         Float               @default(0)
  otherFee          Float               @default(0)
  adjustment        Float               @default(0)
  adjustmentType    String              @default("amount")
  adjustmentAmount  Float               @default(0)
  customerId        String
  projectId         String?
  deletedAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deductions        Json?               @default("[]")
  lockedAt          DateTime?
  parentId          String?
  revision          Int                 @default(1)
  approvalStatus    String              @default("draft")
  approvedAt        DateTime?
  approvedBy        String              @default("")
  lastViewedAt      DateTime?
  sentAt            DateTime?
  sentTo            String              @default("")
  shareToken        String?             @unique @default(uuid())
  viewCount         Int                 @default(0)
  signatureData     String              @default("")
  signatureIp       String              @default("")
  signedAt          DateTime?
  signedByName      String              @default("")
  contracts         Contract[]
  furnitureOrders   FurnitureOrder[]
  customer          Customer            @relation(fields: [customerId], references: [id])
  parent            Quotation?          @relation("QuotationRevisions", fields: [parentId], references: [id])
  children          Quotation[]         @relation("QuotationRevisions")
  project           Project?            @relation(fields: [projectId], references: [id])
  categories        QuotationCategory[]
  items             QuotationItem[]
  purchaseOrders    PurchaseOrder[]
  acceptanceCertificates AcceptanceCertificate[]

  @@index([customerId])
  @@index([projectId])
  @@index([parentId])
  @@index([shareToken])
}

model QuotationCategory {
  id          String          @id @default(cuid())
  name        String
  order       Int             @default(0)
  subtotal    Float           @default(0)
  quotationId String
  group       String          @default("")
  image       String          @default("")
  quotation   Quotation       @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  items       QuotationItem[]

  @@index([quotationId])
}

model QuotationItem {
  id                  String               @id @default(cuid())
  name                String
  order               Int                  @default(0)
  unit                String               @default("")
  quantity            Float                @default(0)
  mainMaterial        Float                @default(0)
  auxMaterial         Float                @default(0)
  labor               Float                @default(0)
  unitPrice           Float                @default(0)
  amount              Float                @default(0)
  description         String               @default("")
  length              Float                @default(0)
  width               Float                @default(0)
  height              Float                @default(0)
  image               String               @default("")
  productId           String?
  quotationId         String
  categoryId          String?
  parentItemId        String?
  volume              Float                @default(0)
  attachments         Json?                @default("[]")
  bodyColorCode       String               @default("")
  bodyColorImage      String               @default("")
  bodyColorName       String               @default("")
  doorColorCode       String               @default("")
  doorColorImage      String               @default("")
  doorColorName       String               @default("")
  functionalImages    Json?                @default("[]")
  functionality       String               @default("")
  hardware            String               @default("")
  renderImage         String               @default("")
  furnitureOrderItems FurnitureOrderItem[]
  category            QuotationCategory?   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  parentItem          QuotationItem?       @relation("SubItems", fields: [parentItemId], references: [id], onDelete: Cascade)
  subItems            QuotationItem[]      @relation("SubItems")
  product             Product?             @relation(fields: [productId], references: [id])
  quotation           Quotation            @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@index([parentItemId])
}

model Warehouse {
  id           String                 @id @default(cuid())
  code         String                 @unique
  name         String
  address      String                 @default("")
  createdAt    DateTime               @default(now())
  isDefault    Boolean                @default(false)
  manager      String                 @default("")
  phone        String                 @default("")
  status       String                 @default("Hoạt động")
  inventoryTx  InventoryTransaction[]
  transfersOut WarehouseTransfer[]    @relation("TransferFrom")
  transfersIn  WarehouseTransfer[]    @relation("TransferTo")
  receipts     GoodsReceipt[]
  stockIssues  StockIssue[]
  stockTakings StockTaking[]
  products     Product[]
}

model InventoryTransaction {
  id                   String              @id @default(cuid())
  code                 String              @unique
  type                 String
  quantity             Float
  unit                 String              @default("")
  note                 String              @default("")
  date                 DateTime            @default(now())
  productId            String
  warehouseId          String
  projectId            String?
  createdAt            DateTime            @default(now())
  furnitureOrderItemId String?
  productionBatchId    String?
  furnitureOrderItem   FurnitureOrderItem? @relation(fields: [furnitureOrderItemId], references: [id])
  product              Product             @relation(fields: [productId], references: [id])
  productionBatch      ProductionBatch?    @relation(fields: [productionBatchId], references: [id])
  project              Project?            @relation(fields: [projectId], references: [id])
  warehouse            Warehouse           @relation(fields: [warehouseId], references: [id])

  @@index([productId])
  @@index([projectId])
  @@index([furnitureOrderItemId])
  @@index([productionBatchId])
}

model Transaction {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String
  description String
  amount      Float
  category    String   @default("")
  date        DateTime @default(now())
  projectId      String?
  paymentAccount String   @default("")
  createdAt      DateTime @default(now())
  project        Project? @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model Department {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  employees Employee[]
}

model Employee {
  id               String             @id @default(cuid())
  code             String             @unique
  name             String
  position         String             @default("")
  phone            String             @default("")
  email            String             @default("")
  salary           Float              @default(0)
  status           String             @default("Đang làm")
  joinDate         DateTime?
  departmentId     String
  deletedAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  insuranceSalary  Float              @default(0)
  address          String             @default("")
  avatar           String             @default("")
  bankAccount      String             @default("")
  bankName         String             @default("")
  dateOfBirth      DateTime?
  emergencyContact String             @default("")
  emergencyPhone   String             @default("")
  gender           String             @default("")
  idNumber         String             @default("")
  leaveBalance       Float              @default(12)
  payrollType        String             @default("office")   // "office" | "workshop"
  positionAllowance  Int                @default(0)
  phoneAllowance     Int                @default(0)
  transportAllowance Int                @default(0)
  diligenceAllowance Int                @default(0)
  mealAllowanceRate  Int                @default(0)           // tiền ăn/ngày cho xưởng
  dailyWage          Int                @default(0)           // lương ngày cho xưởng
  larkId             String             @default("")          // Lark user ID (ou_xxx) để nhắn tin
  officePayrolls     OfficePayrollRecord[]
  workshopPayrolls   WorkshopPayrollRecord[]
  contractCommissions ContractCommission[]
  attendances      Attendance[]
  dailyAttendances DailyAttendance[]
  department       Department         @relation(fields: [departmentId], references: [id])
  contracts        EmployeeContract[]
  reviews          EmployeeReview[]
  leaveRequests    LeaveRequest[]
  payrollRecords   PayrollRecord[]
  projects         ProjectEmployee[]
  salaryAdvances   SalaryAdvance[]
}

model OfficePayrollRecord {
  id                 String   @id @default(cuid())
  employeeId         String
  month              Int
  year               Int
  standardDays       Int      @default(26)
  actualDays         Float    @default(0)
  holidayDays        Float    @default(0)
  paidLeaveDays      Float    @default(0)
  baseSalary         Float    @default(0)
  proratedSalary     Float    @default(0)
  positionAllowance  Float    @default(0)
  phoneAllowance     Float    @default(0)
  transportAllowance Float    @default(0)
  diligenceAllowance Float    @default(0)
  commissionAmount   Float    @default(0)
  bonus              Float    @default(0)
  grossIncome        Float    @default(0)
  bhxhEmployee       Float    @default(0)
  bhytEmployee       Float    @default(0)
  bhtnEmployee       Float    @default(0)
  bhxhCompany        Float    @default(0)
  disciplinaryFine   Float    @default(0)
  salaryAdvance      Float    @default(0)
  totalDeductions    Float    @default(0)
  totalCompanyPays   Float    @default(0)
  netSalary          Float    @default(0)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  employee           Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
}

model WorkshopPayrollRecord {
  id                 String   @id @default(cuid())
  employeeId         String
  month              Int
  year               Int
  dailyWage          Float    @default(0)
  actualDays         Float    @default(0)
  basePay            Float    @default(0)
  overtimeHours      Float    @default(0)
  overtimePay        Float    @default(0)
  mealAllowance      Float    @default(0)
  phoneAllowance     Float    @default(0)
  transportAllowance Float    @default(0)
  diligenceAllowance Float    @default(0)
  bonus              Float    @default(0)
  grossIncome        Float    @default(0)
  disciplinaryFine   Float    @default(0)
  salaryAdvance      Float    @default(0)
  totalDeductions    Float    @default(0)
  netSalary          Float    @default(0)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  employee           Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
}

model ContractCommission {
  id         String   @id @default(cuid())
  employeeId String
  contractId String
  rate       Float
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id])
  contract   Contract @relation(fields: [contractId], references: [id])

  @@unique([employeeId, contractId])
}

model ProjectEmployee {
  projectId  String
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  project    Project  @relation(fields: [projectId], references: [id])

  @@id([projectId, employeeId])
}

model Contractor {
  id             String                 @id @default(cuid())
  code           String                 @unique
  name           String
  type           String
  phone          String                 @default("")
  address        String                 @default("")
  taxCode        String                 @default("")
  bankAccount    String                 @default("")
  bankName       String                 @default("")
  rating         Int                    @default(3)
  notes          String                 @default("")
  deletedAt      DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  creditLimit    Float                  @default(0)
  isBlacklisted  Boolean                @default(false)
  advanceAmount  Float                  @default(0)
  category       String                 @default("")
  openingBalance Float                  @default(0)
  payments       ContractorPayment[]
  paymentLogs    ContractorPaymentLog[]
  documents      ProjectDocument[]
  tasks          SubContractorTask[]
  debts          ContractorDebt[]
}

model ContractorPaymentLog {
  id           String     @id @default(cuid())
  code         String     @unique
  contractorId String
  projectId    String?
  amount       Float
  date         DateTime   @default(now())
  notes        String     @default("")
  createdById  String?
  createdAt    DateTime   @default(now())
  expenseId    String?    @unique
  contractor   Contractor @relation(fields: [contractorId], references: [id])
  project      Project?   @relation(fields: [projectId], references: [id])
}

model ContractorPayment {
  id                String                  @id @default(cuid())
  contractAmount    Float                   @default(0)
  paidAmount        Float                   @default(0)
  status            String                  @default("pending_technical")
  description       String                  @default("")
  dueDate           DateTime?
  contractorId      String
  projectId         String
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  approvedAt        DateTime?
  approvedBy        String                  @default("")
  paymentAccount    String                  @default("")
  attachments       Json?
  netAmount         Float                   @default(0)
  phase             String                  @default("")
  retentionAmount   Float                   @default(0)
  retentionRate     Float                   @default(5)
  retentionReleased Boolean                 @default(false)
  contractor        Contractor              @relation(fields: [contractorId], references: [id])
  project           Project                 @relation(fields: [projectId], references: [id])
  items             ContractorPaymentItem[]

  @@index([projectId])
  @@index([contractorId])
}

model ContractorPaymentItem {
  id                  String            @id @default(cuid())
  description         String
  unit                String            @default("")
  quantity            Float             @default(0)
  unitPrice           Float             @default(0)
  amount              Float             @default(0)
  notes               String            @default("")
  acceptedAt          DateTime          @default(now())
  contractorPaymentId String
  contractorPayment   ContractorPayment @relation(fields: [contractorPaymentId], references: [id], onDelete: Cascade)

  @@index([contractorPaymentId])
}

model Supplier {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  type             String            @default("Vật tư xây dựng")
  contact          String            @default("")
  phone            String            @default("")
  email            String            @default("")
  address          String            @default("")
  taxCode          String            @default("")
  bankAccount      String            @default("")
  bankName         String            @default("")
  rating           Int               @default(3)
  notes            String            @default("")
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  creditLimit      Float             @default(0)
  isBlacklisted    Boolean           @default(false)
  openingBalance   Float             @default(0)
  documents        ProjectDocument[]
  purchaseOrders   PurchaseOrder[]
  supplierPayments SupplierPayment[]
  debts            SupplierDebt[]
}

model SupplierPayment {
  id          String   @id @default(cuid())
  code        String   @unique
  supplierId  String
  amount      Float
  date        DateTime @default(now())
  notes          String   @default("")
  paymentAccount String   @default("")
  createdById    String?
  createdAt      DateTime @default(now())
  expenseId   String?  @unique
  supplier       Supplier @relation(fields: [supplierId], references: [id])
}

model ProjectMilestone {
  id                String             @id @default(cuid())
  name              String
  progress          Int                @default(0)
  startDate         DateTime?
  endDate           DateTime?
  status            String             @default("Chưa bắt đầu")
  order             Int                @default(0)
  projectId         String
  createdAt         DateTime           @default(now())
  acceptanceReports AcceptanceReport[]
  project           Project            @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model ProjectBudget {
  id           String  @id @default(cuid())
  category     String
  budgetAmount Float   @default(0)
  actualAmount Float   @default(0)
  notes        String  @default("")
  projectId    String
  project      Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model ContractAddendum {
  id          String    @id @default(cuid())
  code        String    @unique
  title       String
  description String    @default("")
  amount      Float     @default(0)
  signDate    DateTime?
  status      String    @default("Nháp")
  fileUrl     String    @default("")
  contractId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model Contract {
  id              String             @id @default(cuid())
  code            String             @unique
  name            String
  type            String             @default("Thi công")
  contractValue   Float              @default(0)
  paidAmount      Float              @default(0)
  variationAmount Float              @default(0)
  status          String             @default("Nháp")
  signDate        DateTime?
  startDate       DateTime?
  endDate         DateTime?
  paymentTerms    String             @default("")
  notes           String             @default("")
  fileUrl         String             @default("")
  customerId      String
  projectId       String?
  quotationId     String?
  deletedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  contractBody    String             @default("")
  selectedItems   Json?              @default("[]")
  templateId      String             @default("")
  lastViewedAt    DateTime?
  sentAt          DateTime?
  sentTo          String             @default("")
  viewCount       Int                @default(0)
  signatureData   String             @default("")
  signatureIp     String             @default("")
  signedAt        DateTime?
  signedByName    String             @default("")
  arOpeningPaid   Float              @default(0)
  customer        Customer           @relation(fields: [customerId], references: [id])
  project         Project?           @relation(fields: [projectId], references: [id])
  quotation       Quotation?         @relation(fields: [quotationId], references: [id])
  addenda         ContractAddendum[]
  payments        ContractPayment[]
  furnitureOrders FurnitureOrder[]
  commissions     ContractCommission[]

  @@index([projectId])
  @@index([customerId])
  @@index([quotationId])
}

model ContractPayment {
  id                  String              @id @default(cuid())
  phase               String
  amount              Float               @default(0)
  paidAmount          Float               @default(0)
  category            String              @default("Hợp đồng")
  status              String              @default("Chưa thu")
  dueDate             DateTime?
  paidDate            DateTime?
  notes               String              @default("")
  paymentAccount      String              @default("")
  proofUrl            String              @default("")
  proofFiles          Json                @default("[]")
  contractId          String
  createdAt           DateTime            @default(now())
  retentionAmount     Float               @default(0)
  retentionRate       Float               @default(0)
  retentionReleasedAt DateTime?
  isVariation         Boolean             @default(false)
  contract            Contract            @relation(fields: [contractId], references: [id], onDelete: Cascade)
  corrections         PaymentCorrection[]

  @@index([contractId])
}

model PaymentCorrection {
  id                String          @id @default(cuid())
  contractPaymentId String
  contractId        String
  oldAmount         Float
  newAmount         Float
  reason            String
  status            String          @default("pending")
  rejectionNote     String          @default("")
  requestedBy       String
  reviewedBy        String?
  createdAt         DateTime        @default(now())
  reviewedAt        DateTime?
  contractPayment   ContractPayment @relation(fields: [contractPaymentId], references: [id], onDelete: Cascade)

  @@index([contractPaymentId])
  @@index([status])
}

model WorkOrder {
  id             String        @id @default(cuid())
  code           String        @unique
  title          String
  description    String        @default("")
  priority       String        @default("Trung bình")
  status         String        @default("Chờ xử lý")
  assignee       String        @default("")
  dueDate        DateTime?
  completedAt    DateTime?
  category       String        @default("")
  projectId      String
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  images         String        @default("[]")
  scheduleTaskId String?
  project        Project       @relation(fields: [projectId], references: [id])
  scheduleTask   ScheduleTask? @relation("TaskWorkOrders", fields: [scheduleTaskId], references: [id])

  @@index([projectId])
  @@index([scheduleTaskId])
}

model MaterialPlan {
  id              String                @id @default(cuid())
  quantity        Float                 @default(0)
  orderedQty      Float                 @default(0)
  receivedQty     Float                 @default(0)
  unitPrice       Float                 @default(0)
  totalAmount     Float                 @default(0)
  status          String                @default("Chưa đặt")
  type            String                @default("Chính")
  notes           String                @default("")
  productId       String
  projectId       String
  createdAt       DateTime              @default(now())
  budgetUnitPrice Float                 @default(0)
  category        String                @default("")
  isLocked        Boolean               @default(false)
  wastePercent    Float                 @default(5)
  costType        String                @default("Vật tư")
  drawingNote     String                @default("")
  drawingUrl      String                @default("")
  group1          String                @default("")
  group2          String                @default("")
  supplierTag     String                @default("")
  product         Product               @relation(fields: [productId], references: [id])
  project         Project               @relation(fields: [projectId], references: [id])
  requisitions    MaterialRequisition[]
  purchaseItems   PurchaseOrderItem[]

  @@index([projectId])
  @@index([productId])
}

model BudgetChangeOrder {
  id             String   @id @default(cuid())
  projectId      String
  materialPlanId String?
  reason         String
  oldQty         Float    @default(0)
  newQty         Float    @default(0)
  oldPrice       Float    @default(0)
  newPrice       Float    @default(0)
  status         String   @default("pending")
  requestedBy    String   @default("")
  approvedBy     String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model MaterialRequisition {
  id              String         @id @default(cuid())
  code            String         @unique
  requestedQty    Float          @default(0)
  requestedDate   DateTime?
  notes           String         @default("")
  status          String         @default("Chờ xử lý")
  createdBy       String         @default("")
  materialPlanId  String
  projectId       String
  purchaseOrderId String?
  createdAt       DateTime       @default(now())
  receiveNotes    String         @default("")
  receivedAt      DateTime?
  receivedBy      String         @default("")
  receivedPhotos  Json?          @default("[]")
  receivedQty     Float          @default(0)
  materialPlan    MaterialPlan   @relation(fields: [materialPlanId], references: [id])
  project         Project        @relation(fields: [projectId], references: [id])
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@index([projectId])
  @@index([materialPlanId])
}

model PurchaseOrder {
  id              String                @id @default(cuid())
  code            String                @unique
  supplier        String
  totalAmount     Float                 @default(0)
  paidAmount      Float                 @default(0)
  status          String                @default("Chờ duyệt")
  orderDate       DateTime              @default(now())
  deliveryDate    DateTime?
  receivedDate    DateTime?
  furnitureOrderId String?
  materialType     String?
  notes           String                @default("")
  projectId       String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deliveryAddress String                @default("")
  deliveryType    String                @default("Giao thẳng dự án")
  supplierId      String?
  quotationId     String?
  requisitions    MaterialRequisition[]
  project         Project?              @relation(fields: [projectId], references: [id])
  supplierRel     Supplier?             @relation(fields: [supplierId], references: [id])
  quotation       Quotation?            @relation(fields: [quotationId], references: [id])
  items           PurchaseOrderItem[]
  receipts        GoodsReceipt[]
  furnitureMaterialOrder FurnitureMaterialOrder?

  @@index([projectId])
  @@index([supplierId])
  @@index([quotationId])
  @@index([furnitureOrderId])
}

model PurchaseOrderItem {
  id                   String              @id @default(cuid())
  productName          String
  unit                 String              @default("")
  quantity             Float               @default(0)
  unitPrice            Float               @default(0)
  amount               Float               @default(0)
  receivedQty          Float               @default(0)
  notes                String              @default("")
  variantLabel         String              @default("")
  productId            String?
  purchaseOrderId      String
  materialPlanId       String?
  furnitureOrderItemId String?
  projectId            String?
  furnitureOrderItem   FurnitureOrderItem? @relation(fields: [furnitureOrderItemId], references: [id])
  materialPlan         MaterialPlan?       @relation(fields: [materialPlanId], references: [id])
  product              Product?            @relation(fields: [productId], references: [id])
  purchaseOrder        PurchaseOrder       @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  project              Project?            @relation("PurchaseOrderItemProject", fields: [projectId], references: [id])
  receiptItems         GoodsReceiptItem[]

  @@index([purchaseOrderId])
  @@index([materialPlanId])
  @@index([furnitureOrderItemId])
  @@index([projectId])
}

model ProjectExpense {
  id              String              @id @default(cuid())
  code            String              @unique
  expenseType     String              @default("Dự án")
  description     String
  amount          Float               @default(0)
  paidAmount      Float               @default(0)
  category        String              @default("Khác")
  status          String              @default("Chờ duyệt")
  submittedBy     String              @default("")
  approvedBy      String              @default("")
  proofUrl        String              @default("")
  recipientType   String              @default("")
  recipientId     String              @default("")
  recipientName   String              @default("")
  date            DateTime            @default(now())
  notes           String              @default("")
  paymentAccount  String              @default("")
  projectId       String?
  deletedAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  categoryId      String?
  allocations     ExpenseAllocation[]
  expenseCategory ExpenseCategory?    @relation(fields: [categoryId], references: [id])
  project         Project?            @relation(fields: [projectId], references: [id])
  supplierDebt    SupplierDebt?       @relation("SupplierDebtFromExpense")
  contractorDebt  ContractorDebt?     @relation("ContractorDebtFromExpense")

  @@index([projectId])
  @@index([categoryId])
}

model ExpenseCategory {
  id          String            @id @default(cuid())
  name        String            @unique
  code        String            @unique
  description String            @default("")
  parentId    String?
  linkType    String            @default("")
  isActive    Boolean           @default(true)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  parent      ExpenseCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    ExpenseCategory[] @relation("CategoryTree")
  expenses         ProjectExpense[]
  overheadExpenses OverheadExpense[]

  @@index([parentId])
}

model ExpenseAllocation {
  id        String         @id @default(cuid())
  expenseId String
  projectId String
  amount    Float          @default(0)
  ratio     Float          @default(0)
  notes     String         @default("")
  createdAt DateTime       @default(now())
  expense   ProjectExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  project   Project        @relation(fields: [projectId], references: [id])

  @@unique([expenseId, projectId])
  @@index([expenseId])
  @@index([projectId])
}

model TrackingLog {
  id            String    @id @default(cuid())
  content       String
  type          String    @default("Ghi chú")
  contactMethod String    @default("")
  nextFollowUp  DateTime?
  createdBy     String    @default("")
  customerId    String?
  projectId     String?
  createdAt     DateTime  @default(now())
  customer      Customer? @relation(fields: [customerId], references: [id])
  project       Project?  @relation(fields: [projectId], references: [id])

  @@index([customerId])
  @@index([projectId])
}

model ProjectDocument {
  id               String            @id @default(cuid())
  name             String
  fileName         String            @default("")
  category         String            @default("Khác")
  fileSize         Int               @default(0)
  uploadedBy       String            @default("")
  notes            String            @default("")
  customerId       String?
  projectId        String?
  createdAt        DateTime          @default(now())
  fileUrl          String            @default("")
  mimeType         String            @default("")
  status           String            @default("Nháp")
  version          Int               @default(1)
  parentDocumentId String?
  folderId         String?
  accessLevel      String            @default("internal")
  space            String            @default("")
  thumbnailUrl     String            @default("")
  contractorId     String?
  supplierId       String?
  contractor       Contractor?       @relation(fields: [contractorId], references: [id])
  customer         Customer?         @relation(fields: [customerId], references: [id])
  folder           DocumentFolder?   @relation(fields: [folderId], references: [id])
  parentDoc        ProjectDocument?  @relation("DocVersions", fields: [parentDocumentId], references: [id])
  versions         ProjectDocument[] @relation("DocVersions")
  project          Project?          @relation(fields: [projectId], references: [id])
  supplier         Supplier?         @relation(fields: [supplierId], references: [id])

  @@index([projectId])
  @@index([customerId])
  @@index([supplierId])
  @@index([contractorId])
}

model DocumentFolder {
  id        String            @id @default(cuid())
  name      String
  order     Int               @default(0)
  parentId  String?
  projectId String
  createdAt DateTime          @default(now())
  parent    DocumentFolder?   @relation("FolderTree", fields: [parentId], references: [id])
  children  DocumentFolder[]  @relation("FolderTree")
  project   Project           @relation(fields: [projectId], references: [id])
  documents ProjectDocument[]

  @@index([projectId])
}

model ProductBOM {
  id          String   @id @default(cuid())
  quantity    Float    @default(1)
  unit        String   @default("")
  notes       String   @default("")
  productId   String
  componentId String
  createdAt   DateTime @default(now())
  component   Product  @relation("BOMComponent", fields: [componentId], references: [id])
  product     Product  @relation("BOMParent", fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([componentId])
}

model ProductAttribute {
  id        String                   @id @default(cuid())
  name      String
  inputType String                   @default("select")
  required  Boolean                  @default(true)
  order     Int                      @default(0)
  productId String
  createdAt DateTime                 @default(now())
  product   Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  options   ProductAttributeOption[]

  @@index([productId])
}

model ProductAttributeOption {
  id          String           @id @default(cuid())
  label       String
  priceAddon  Float            @default(0)
  order       Int              @default(0)
  attributeId String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@index([attributeId])
}

model VariantTemplate {
  id        String                  @id @default(cuid())
  name      String
  inputType String                  @default("select")
  required  Boolean                 @default(true)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  options   VariantTemplateOption[]
}

model VariantTemplateOption {
  id         String          @id @default(cuid())
  label      String
  priceAddon Float           @default(0)
  order      Int             @default(0)
  templateId String
  template   VariantTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model WorkItemLibrary {
  id           String   @id @default(cuid())
  name         String
  category     String   @default("Phần thô")
  subcategory  String   @default("")
  unit         String   @default("m²")
  mainMaterial Float    @default(0)
  auxMaterial  Float    @default(0)
  labor        Float    @default(0)
  unitPrice    Float    @default(0)
  description  String   @default("")
  image        String   @default("")
  createdAt    DateTime @default(now())
}

model QuotationTemplate {
  id                String                      @id @default(cuid())
  name              String
  type              String                      @default("Thi công thô")
  description       String                      @default("")
  managementFeeRate Float                       @default(5)
  designFee         Float                       @default(0)
  vat               Float                       @default(10)
  discount          Float                       @default(0)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  categories        QuotationTemplateCategory[]
}

model QuotationTemplateCategory {
  id         String                  @id @default(cuid())
  name       String
  order      Int                     @default(0)
  templateId String
  template   QuotationTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items      QuotationTemplateItem[]
}

model QuotationTemplateItem {
  id           String                    @id @default(cuid())
  name         String
  order        Int                       @default(0)
  unit         String                    @default("")
  quantity     Float                     @default(0)
  mainMaterial Float                     @default(0)
  auxMaterial  Float                     @default(0)
  labor        Float                     @default(0)
  unitPrice    Float                     @default(0)
  description  String                    @default("")
  categoryId   String
  category     QuotationTemplateCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model ScheduleTask {
  id              String              @id @default(cuid())
  name            String
  order           Int                 @default(0)
  level           Int                 @default(0)
  wbs             String              @default("")
  startDate       DateTime
  endDate         DateTime
  duration        Int                 @default(1)
  progress        Int                 @default(0)
  weight          Float               @default(1)
  status          String              @default("Chưa bắt đầu")
  assignee        String              @default("")
  notes           String              @default("")
  color           String              @default("")
  baselineStart   DateTime?
  baselineEnd     DateTime?
  parentId        String?
  predecessorId   String?
  projectId       String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  isLocked        Boolean             @default(false)
  progressReports ProgressReport[]
  parent          ScheduleTask?       @relation("TaskTree", fields: [parentId], references: [id])
  children        ScheduleTask[]      @relation("TaskTree")
  predecessor     ScheduleTask?       @relation("TaskDep", fields: [predecessorId], references: [id])
  successors      ScheduleTask[]      @relation("TaskDep")
  project         Project             @relation(fields: [projectId], references: [id])
  contractors     SubContractorTask[]
  dependents      TaskDependency[]    @relation("TaskDependents")
  dependencies    TaskDependency[]    @relation("TaskDependencies")
  workOrders      WorkOrder[]         @relation("TaskWorkOrders")

  @@index([projectId])
  @@index([parentId])
}

model TaskDependency {
  id          String       @id @default(cuid())
  taskId      String
  dependsOnId String
  type        String       @default("FS")
  lag         Int          @default(0)
  createdAt   DateTime     @default(now())
  dependsOn   ScheduleTask @relation("TaskDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)
  task        ScheduleTask @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
}

model SubContractorTask {
  id                String       @id @default(cuid())
  contractorId      String
  taskId            String
  assignedAt        DateTime     @default(now())
  completionPercent Int          @default(0)
  notes             String       @default("")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  contractor        Contractor   @relation(fields: [contractorId], references: [id])
  task              ScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([contractorId, taskId])
  @@index([contractorId])
  @@index([taskId])
}

model ProgressReport {
  id            String       @id @default(cuid())
  progressFrom  Int          @default(0)
  progressTo    Int
  description   String       @default("")
  images        String       @default("[]")
  status        String       @default("Đã duyệt")
  rejectionNote String       @default("")
  reportDate    DateTime     @default(now())
  createdBy     String       @default("")
  taskId        String
  projectId     String
  createdAt     DateTime     @default(now())
  project       Project      @relation(fields: [projectId], references: [id])
  task          ScheduleTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([projectId])
}

model ScheduleTemplate {
  id          String                 @id @default(cuid())
  name        String
  type        String                 @default("Nội thất")
  description String                 @default("")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  items       ScheduleTemplateItem[]
}

model ScheduleTemplateItem {
  id            String                 @id @default(cuid())
  name          String
  order         Int                    @default(0)
  level         Int                    @default(0)
  wbs           String                 @default("")
  duration      Int                    @default(1)
  weight        Float                  @default(1)
  color         String                 @default("")
  parentId      String?
  predecessorId String?
  templateId    String
  parent        ScheduleTemplateItem?  @relation("TplItemTree", fields: [parentId], references: [id])
  children      ScheduleTemplateItem[] @relation("TplItemTree")
  predecessor   ScheduleTemplateItem?  @relation("TplItemDep", fields: [predecessorId], references: [id])
  successors    ScheduleTemplateItem[] @relation("TplItemDep")
  template      ScheduleTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id          String       @id @default(cuid())
  projectId   String
  source      String       @default("paste")
  rawInput    String
  aiSummary   String?
  aiRaw       Json?
  createdBy   String       @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  commitments Commitment[]
  project     Project      @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model Commitment {
  id             String        @id @default(cuid())
  journalEntryId String?
  projectId      String
  title          String
  type           String        @default("yêu cầu")
  assignee       String        @default("")
  deadline       DateTime?
  status         String        @default("pending")
  notes          String        @default("")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  project        Project       @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([journalEntryId])
  @@index([status])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actor       String   @default("")
  actorId     String   @default("")
  action      String
  entityType  String
  entityId    String
  entityLabel String   @default("")
  diff        Json?
  metadata    Json?
  ipAddress   String   @default("")
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actor])
  @@index([createdAt])
}

model PunchListItem {
  id          String    @id @default(cuid())
  projectId   String
  area        String    @default("")
  description String
  images      String    @default("[]")
  assignee    String    @default("")
  assigneeId  String?
  priority    String    @default("Trung bình")
  deadline    DateTime?
  status      String    @default("Mở")
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([assigneeId])
}

model Attendance {
  id          String   @id @default(cuid())
  employeeId  String
  month       Int
  year        Int
  workDays    Float    @default(0)
  leaveDays   Float    @default(0)
  unpaidDays  Float    @default(0)
  overtimeHrs Float    @default(0)
  bonus       Float    @default(0)
  deduction   Float    @default(0)
  netSalary   Float    @default(0)
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@index([employeeId])
}

model LeaveRequest {
  id         String    @id @default(cuid())
  employeeId String
  type       String    @default("Nghỉ phép năm")
  startDate  DateTime
  endDate    DateTime
