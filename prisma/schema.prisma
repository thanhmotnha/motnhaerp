  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  month       Int
  year        Int
  workDays    Float    @default(0)
  leaveDays   Float    @default(0)
  unpaidDays  Float    @default(0)
  overtimeHrs Float    @default(0)
  bonus       Float    @default(0)
  deduction   Float    @default(0)
  netSalary   Float    @default(0)
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([employeeId, month, year])
  @@index([employeeId])
}

// ============ ĐƠN NGHỈ PHÉP ============

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  type       String   @default("Nghỉ phép năm")
  startDate  DateTime
  endDate    DateTime
  days       Float    @default(1)
  reason     String   @default("") @db.Text
  status     String   @default("Chờ duyệt")
  approvedBy String   @default("")
  approvedAt DateTime?
  rejectNote String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([employeeId])
  @@index([status])
}

// ============ BẢO HÀNH ============

model WarrantyTicket {
