  code             String   @unique
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id])
  furnitureOrderId String?
  furnitureOrder   FurnitureOrder? @relation(fields: [furnitureOrderId], references: [id])
  title            String
  description      String   @default("") @db.Text
  reportedBy       String   @default("")
  assignee         String   @default("")
  priority         String   @default("Trung bình")
  status           String   @default("Mới")
  resolvedAt       DateTime?
  images           String   @default("[]") @db.Text
  notes            String   @default("") @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  @@index([projectId])
  @@index([furnitureOrderId])
  @@index([status])
}

// ============ NHẬT KÝ CÔNG TRÌNH ============

model SiteLog {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  date        DateTime @default(now())
  weather     String   @default("Nắng")
  workerCount Int      @default(0)
  progress    String   @default("") @db.Text
  issues      String   @default("") @db.Text
  images      String   @default("[]") @db.Text
  createdBy   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([projectId])
  @@index([date])
}

// ============================================================
// MODULE: NỘI THẤT MAY ĐO (Custom Furniture)
// ============================================================

// ── Xưởng sản xuất nội bộ ──────────────────────────────────
model Workshop {
  id        String   @id @default(cuid())
  code      String   @unique // XS-01, XS-02
  name      String
  address   String   @default("")
  phone     String   @default("")
  managerId String?  // userId trưởng xưởng
  capacity  Int      @default(0)
  isActive  Boolean  @default(true)
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batches   ProductionBatch[]
  @@index([isActive])
}

// ── Đơn hàng nội thất ──────────────────────────────────────
model FurnitureOrder {
  id               String   @id @default(cuid())
  code             String   @unique // NT-2026-001
  name             String

  customerId       String
  customer         Customer  @relation(fields: [customerId], references: [id])
  projectId        String?   // null = đơn độc lập
  project          Project?  @relation(fields: [projectId], references: [id])
  quotationId      String?
  quotation        Quotation? @relation(fields: [quotationId], references: [id])
  contractId       String?
  contract         Contract?  @relation(fields: [contractId], references: [id])

  description      String   @default("") @db.Text
  styleNote        String   @default("")
  roomType         String   @default("")
  deliveryAddress  String   @default("") @db.Text
  internalNote     String   @default("") @db.Text

  // Tài chính stored — cập nhật qua API transaction khi item thay đổi
  confirmedAmount  Float    @default(0)
  cancelledAmount  Float    @default(0)
  depositAmount    Float    @default(0)
  paidAmount       Float    @default(0)

  // draft | confirmed | design_review | design_approved | material_confirmed
  // | in_production | qc_done | installing | completed | cancelled
  status           String   @default("draft")

  salesperson      String   @default("")
  designer         String   @default("")

  expectedDelivery DateTime?
  deliveredAt      DateTime?

  publicToken      String?  @unique
  tokenExpiresAt   DateTime?

  createdBy        String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items              FurnitureOrderItem[]
  designs            DesignVersion[]
  materialSelections MaterialSelection[]
  batches            ProductionBatch[]
  payments           FurniturePayment[]
  warrantyTickets    WarrantyTicket[]

  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([code])
  @@index([publicToken])
}

// ── Từng món đồ trong đơn ──────────────────────────────────
model FurnitureOrderItem {
  id               String   @id @default(cuid())
  furnitureOrderId String
  furnitureOrder   FurnitureOrder @relation(fields: [furnitureOrderId], references: [id], onDelete: Cascade)
  sortOrder        Int      @default(0)

  quotationItemId  String?
  quotationItem    QuotationItem? @relation(fields: [quotationItemId], references: [id])
  productId        String?
  product          Product?  @relation(fields: [productId], references: [id])

  // Snapshot tại thời điểm confirm
  name             String
  description      String   @default("")
  unit             String   @default("bộ")
  quantity         Float    @default(1)
  unitPrice        Float    @default(0)
  amount           Float    @default(0)

  specs            Json?    // { width, height, depth, material, color, ... }

  // confirmed | cancelled | on_hold | in_production | completed | delivered
  status           String   @default("confirmed")
  cancelReason     String   @default("")

  expectedDate     DateTime?
  completedAt      DateTime?
  deliveredAt      DateTime?
  notes            String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  batchItems    ProductionBatchItem[]
  inventoryTxns InventoryTransaction[]
  purchaseItems PurchaseOrderItem[]

  @@index([furnitureOrderId])
  @@index([furnitureOrderId, status])
  @@index([quotationItemId])
  @@index([status])
}

// ── Phiên bản bản vẽ thiết kế ──────────────────────────────
model DesignVersion {
  id               String   @id @default(cuid())
  furnitureOrderId String
  furnitureOrder   FurnitureOrder @relation(fields: [furnitureOrderId], references: [id], onDelete: Cascade)

  versionNumber    Int
  versionLabel     String   @default("")
  description      String   @default("")
  fileUrl          String   @default("")
  renderImageUrl   String   @default("")
  technicalSpec    String   @default("") @db.Text

  // draft | submitted | approved | rejected | superseded
  status           String   @default("draft")
  submittedAt      DateTime?
  submittedBy      String   @default("")

  customerFeedback String   @default("") @db.Text
  approvedAt       DateTime?
  approvedByName   String   @default("")
  approvedIp       String   @default("")
  rejectionReason  String   @default("")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([furnitureOrderId, versionNumber])
  @@index([furnitureOrderId])
  @@index([status])
}

// ── Chốt vật liệu & màu sắc ────────────────────────────────
model MaterialSelection {
  id               String   @id @default(cuid())
  furnitureOrderId String
  furnitureOrder   FurnitureOrder @relation(fields: [furnitureOrderId], references: [id], onDelete: Cascade)

  selectionRound   Int      @default(1)
  title            String   @default("")
  notes            String   @default("") @db.Text

  // pending | reviewing | confirmed | changed
  status           String   @default("pending")

  presentedAt      DateTime?
  presentedBy      String   @default("")

  confirmedAt      DateTime?
  confirmedByName  String   @default("")
  confirmedIp      String   @default("")
  confirmationNote String   @default("")

  items            MaterialSelectionItem[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([furnitureOrderId])
  @@index([status])
}

model MaterialSelectionItem {
  id                  String            @id @default(cuid())
  materialSelectionId String
  materialSelection   MaterialSelection @relation(fields: [materialSelectionId], references: [id], onDelete: Cascade)

  productId           String?
  product             Product?          @relation(fields: [productId], references: [id])

  materialName        String
  materialCode        String   @default("")
  colorName           String   @default("")
  colorCode           String   @default("")
  finishType          String   @default("")
  supplier            String   @default("")
  swatchImageUrl      String   @default("")
  applicationArea     String   @default("")
  quantity            Float    @default(0)
  unit                String   @default("")
  unitPrice           Float    @default(0)
  notes               String   @default("")

  @@index([materialSelectionId])
  @@index([productId])
}

// ── Đợt sản xuất ───────────────────────────────────────────
model ProductionBatch {
  id               String   @id @default(cuid())
  code             String   @unique // BATCH-2026-001
  furnitureOrderId String
  furnitureOrder   FurnitureOrder @relation(fields: [furnitureOrderId], references: [id])
  workshopId       String
  workshop         Workshop @relation(fields: [workshopId], references: [id])

  // planned | in_progress | paused | completed | cancelled
  status           String   @default("planned")

  supervisorName   String   @default("")
  assignedWorkers  String   @default("[]") @db.Text // JSON: [{name, role, phone}]
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  actualStartDate  DateTime?
  actualEndDate    DateTime?
  notes            String   @default("")

  batchItems    ProductionBatchItem[]
  inventoryTxns InventoryTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([furnitureOrderId])
  @@index([workshopId])
  @@index([workshopId, status])
  @@index([status])
}

// ── Junction: Batch ↔ Item ──────────────────────────────────
model ProductionBatchItem {
  id                   String             @id @default(cuid())
  batchId              String
  batch                ProductionBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  furnitureOrderItemId String
  furnitureOrderItem   FurnitureOrderItem @relation(fields: [furnitureOrderItemId], references: [id])

  plannedQty   Float
  completedQty Float    @default(0)

  // pending | in_progress | completed | rejected
  status       String   @default("pending")

  qcPassedQty  Float?
  qcFailedQty  Float?
  qcNote       String   @default("")
  qcAt         DateTime?
  qcBy         String   @default("")
  notes        String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([batchId, furnitureOrderItemId])
  @@index([batchId])
  @@index([furnitureOrderItemId])
}

// ── Thanh toán đơn nội thất ────────────────────────────────
model FurniturePayment {
  id               String   @id @default(cuid())
  furnitureOrderId String
  furnitureOrder   FurnitureOrder @relation(fields: [furnitureOrderId], references: [id])

  amount    Float
  paidAt    DateTime @default(now())
  // deposit | installment | final | refund
  type      String
  method    String   @default("")
  reference String   @default("")
  note      String   @default("")
  createdBy String   @default("")
  createdAt DateTime @default(now())

  @@index([furnitureOrderId])
  @@index([paidAt])
}

// ── Biên bản Nghiệm thu ────────────────────────────────────
model AcceptanceReport {
  id           String   @id @default(cuid())
  code         String   @unique
  title        String
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  milestoneId  String?
  milestone    ProjectMilestone? @relation(fields: [milestoneId], references: [id])
  items        Json     @default("[]") // [{name, status: 'pass'|'fail'|'na', note}]
  notes        String   @default("") @db.Text
  inspector    String   @default("")
  customerRep  String   @default("")
  status       String   @default("Chờ duyệt") // Chờ duyệt, Đạt, Không đạt
  signedAt     DateTime?
  signedByCustomer String @default("")
  createdBy    String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([projectId])
  @@index([milestoneId])
}

// ── Bảng lương chi tiết ─────────────────────────────────────
model PayrollRecord {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  month           Int
  year            Int
  baseSalary      Float    @default(0)
  workDays        Float    @default(0)
  actualDays      Float    @default(0)
  overtimeHours   Float    @default(0)
  overtimePay     Float    @default(0)
  allowances      Float    @default(0) // phụ cấp
  bonus           Float    @default(0)
  bhxhEmployee    Float    @default(0) // BHXH phần NV
  bhxhCompany     Float    @default(0) // BHXH phần cty
  bhytEmployee    Float    @default(0)
  bhtnEmployee    Float    @default(0)
  taxableIncome   Float    @default(0)
  personalTax     Float    @default(0) // Thuế TNCN
  deductions      Float    @default(0) // khấu trừ khác
  advances        Float    @default(0) // tạm ứng
  netSalary       Float    @default(0) // thực lĩnh
  notes           String   @default("")
  status          String   @default("Nháp") // Nháp, Đã duyệt, Đã chi
  approvedBy      String   @default("")
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([month, year])
}

// ── Mẫu đơn nội thất ────────────────────────────────────────
model FurnitureTemplate {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String   @default("")
  category    String   @default("")  // Tủ bếp, Tủ áo, Bàn, Giường...
  roomType    String   @default("")
  styleNote   String   @default("")
  items       String   @default("[]") @db.Text  // JSON: [{name, unit, qty, unitPrice, notes}]
  materials   String   @default("[]") @db.Text  // JSON: [{area, materialName, colorCode, unit, qty}]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([category])
  @@index([isActive])
}

// ============ HỢP ĐỒNG MẪU ============

model ContractTemplate {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("Thi công")
  body      String   @default("") @db.Text
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([type])
}
